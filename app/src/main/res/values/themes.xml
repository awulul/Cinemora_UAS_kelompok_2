<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Gunakan Light (Terang) -->
    <style name="Theme.Cinemora" parent="Theme.Material3.Light.NoActionBar">

        <!-- Warna Utama Aplikasi -->
        <item name="colorPrimary">@color/secondary</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Warna Latar Belakang Seluruh Layar -->
        <item name="android:colorBackground">@color/background</item>

        <!-- Warna Status Bar (Bagian paling atas baterai/jam) -->
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item> <!-- Agar ikon jam/baterai jadi hitam -->
    </style>
</resources>